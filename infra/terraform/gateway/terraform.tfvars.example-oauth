# Gateway with MCP server using OAuth authentication
gateway_name              = "my-gateway"
environment_name          = "dev"
gateway_authorizer_type   = "AWS_IAM"

# MCP Target Configuration
add_mcp_target            = true
mcp_server_endpoint       = "https://your-mcp-server.example.com"
mcp_auth_type             = "OAUTH"

# OAuth Configuration - Google Example
mcp_oauth_config = {
  provider_vendor = "GoogleOauth2"
  client_id       = "your-client-id.apps.googleusercontent.com"
  client_secret   = "your-client-secret"
  scopes          = ["https://www.googleapis.com/auth/userinfo.email"]
}

